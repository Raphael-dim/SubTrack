// Secrets.xcconfig — fichier VERSIONNÉ, sans secret.
//
// Logo.dev permet d'afficher les logos de marque en couleur HD. Pour l'activer :
//
//   1. Crée un compte gratuit sur https://www.logo.dev
//   2. Crée le fichier Config/Secrets.local.xcconfig (non versionné) contenant :
//          LOGODEV_TOKEN = pk_ta_cle_publishable
//
// La clé est *publishable* (préfixe `pk_`), conçue pour le client — mais on la
// garde hors du dépôt par hygiène. Sans token, l'app fonctionne quand même :
// elle retombe sur les favicons puis sur un monogramme coloré.

// Valeur par défaut (vide) — surchargée par Secrets.local.xcconfig s'il existe.
LOGODEV_TOKEN =

// Inclusion optionnelle : ne casse pas le build si le fichier est absent.
#include? "Secrets.local.xcconfig"
